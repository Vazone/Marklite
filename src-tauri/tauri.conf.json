{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkLite",
  "version": "0.1.0",
  "identifier": "com.marklite.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarkLite",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true,
        "decorations": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob: file:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "publisher": "Vazone",
    "copyright": "Copyright (c) 2026 Vazone",
    "shortDescription": "Lightweight Markdown editor",
    "longDescription": "MarkLite is a lightweight Markdown editor for Windows built with Rust, Tauri and Svelte.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
